# Copy this file to .env.local and fill in your values

# Supabase — get these from https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Admin PIN — set this to whatever password you want for the admin area
VITE_ADMIN_PIN=your-secret-pin-here
